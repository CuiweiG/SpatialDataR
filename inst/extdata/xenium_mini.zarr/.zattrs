  "spatialdata_attrs": {
    "version": "0.1",
    "coordinate_systems": {
      "global": {
        "axes": [
          {"name": "x", "type": "space", "unit": "micrometer"},
          {"name": "y", "type": "space", "unit": "micrometer"}
